enum UnitFilterMode {
	ALL_UNITS,       # Counts every unrouted figure on your side
	REQUIRED_TYPES,  # Counts only unit types matching card.required_unit_types
	TIER_0,          # Counts only tier 0 figures
	TIER_1,          # Counts only tier 1 figures
	TIER_2,          # Counts only tier 2 figures
	TIER_3           # Counts only tier 3 figures
}



enum TargetType { SELF, OPPONENT, BOTH }
enum DicePoolType { RANDOM, OFFENSE, DEFENSE, MORALE }
enum TimingWindow {
	INSTANT,         # Resolves immediately when card is revealed (Stage 2)
	BEFORE_DAMAGE,   # Resolves right before offense/defense values match up
	DURING_DAMAGE,   # Resolves after raw damage numbers are calculated, before unit allocation
	AFTER_DAMAGE     # Resolves after figures are safely routed or destroyed
}

